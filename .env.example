# Database
DATABASE_URL=postgresql+asyncpg://theworld:theworld@localhost:5432/theworld
POSTGRES_DB=theworld
POSTGRES_USER=theworld
POSTGRES_PASSWORD=theworld

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Claude API (optional - for Tier 1 AI interactions)
CLAUDE_API_KEY=

# JWT Auth
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Application
APP_ENV=development
APP_DEBUG=true
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Simulation
SIM_TIME_SCALE=1.0
SIM_TICK_INTERVAL_MS=1000
